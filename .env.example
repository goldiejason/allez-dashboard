# ─────────────────────────────────────────────────────────────
# Allez Dashboard — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────────────────

# Supabase — find these at:
# https://supabase.com/dashboard/project/whffigkbnkugzsltkdhq/settings/api-keys/legacy
SUPABASE_URL=https://whffigkbnkugzsltkdhq.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase Postgres — direct DB connection for collection scripts
# Password is what you set when creating the project
SUPABASE_DB_PASSWORD=your_db_password_here

# FTL — FencingTimeLive free account credentials
# Required from 2026-04-14. Register at https://www.fencingtimelive.com/account/login
# Used by collectors/ftl_collector.py to authenticate before fetching results.
FTL_USERNAME=your_ftl_email_here
FTL_PASSWORD=your_ftl_password_here

# UK Ratings — British Fencing club login credentials
# Used by collectors/ukratings_collector.py to scrape athlete pages
UK_RATINGS_USERNAME=your_username_here
UK_RATINGS_PASSWORD=your_password_here
